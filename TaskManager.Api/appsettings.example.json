{
  {
    "Logging": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
      "DefaultConnection": "YOUR_CONNECTION_STRING_HERE"
    },
    "JwtSettings": {
      "SecretKey": "YOUR_SECRET_KEY_HERE_MIN_32_CHARS",
      "Issuer": "TaskManagerApi",
      "Audience": "TaskManagerApiUsers",
      "ExpiryMinutes": 60
    }
  }
}
